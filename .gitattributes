# Auto detect text files and perform LF normalization
* text=auto

# Unity text assets and scripts should stay LF across platforms.
*.cs text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.json text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.mat text eol=lf
*.shader text eol=lf
*.shadergraph text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf
*.vfx text eol=lf
